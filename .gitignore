# MemoryOS .gitignore

# ─── Rust ───────────────────────────────────────────────────────────────────
/target/
**/*.rs.bk
Cargo.lock.bak

# ─── Flutter ────────────────────────────────────────────────────────────────
# Build directories
apps/flutter_app/.dart_tool/
apps/flutter_app/.flutter-plugins
apps/flutter_app/.flutter-plugins-dependencies
apps/flutter_app/.packages
apps/flutter_app/build/
apps/flutter_app/.pub-cache/

# Platform-specific
apps/flutter_app/android/.gradle/
apps/flutter_app/android/local.properties
apps/flutter_app/android/key.properties
apps/flutter_app/ios/Pods/
apps/flutter_app/ios/.symlinks/
apps/flutter_app/macos/Pods/
apps/flutter_app/windows/flutter/ephemeral/
apps/flutter_app/linux/flutter/ephemeral/

# ─── IDE ────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.iml
*.iws
*.ipr

# ─── OS ─────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ─── Docker ─────────────────────────────────────────────────────────────────
.docker/

# ─── Coverage ───────────────────────────────────────────────────────────────
coverage/
lcov.info
tarpaulin-report.html

# ─── Secrets ────────────────────────────────────────────────────────────────
.env
.env.local
*.pem
*.key
*.p12
*.pfx

# ─── Models (large binary files) ────────────────────────────────────────────
*.gguf
*.onnx

# ─── MemoryOS Data ──────────────────────────────────────────────────────────
.memoryos_data/
memoryos_data/
/artifacts/
/data/
/target-dist/
